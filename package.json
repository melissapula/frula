{
  "name": "fsbo-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "yarn workspace @fsbo/web dev",
    "dev:api": "yarn workspace @fsbo/api start:dev",
    "dev": "concurrently \"yarn dev:api\" \"yarn dev:web\"",
    "build:web": "yarn workspace @fsbo/web build",
    "build:api": "yarn workspace @fsbo/api build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
