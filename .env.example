# =============================================
# FSBO Platform — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# =============================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- API ---
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# --- Anthropic (for CMA narratives) ---
# Free tier: generous limits for low volume
ANTHROPIC_API_KEY=your-anthropic-key

# --- Cloudinary (photo uploads) ---
# CLOUDINARY_CLOUD_NAME and CLOUDINARY_UPLOAD_PRESET are exposed to the browser
# (they're public by design — Cloudinary unsigned uploads). Create the preset
# in Cloudinary console: Settings → Upload → Add upload preset → Signing mode: Unsigned.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=frula_listings_unsigned
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

# --- Mapbox (maps + geocoding) ---
MAPBOX_TOKEN=your-mapbox-token

# --- Resend (email notifications) ---
RESEND_API_KEY=your-resend-key
EMAIL_FROM=noreply@yourdomain.com

# --- Stripe (payments — add when ready) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
