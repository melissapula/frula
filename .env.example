# =============================================
# Frula Homes — Environment Variables
# Copy to apps/web/.env and fill in your values
# NEVER commit .env to git
# =============================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Cloudinary (photo uploads) ---
# Public by design — Cloudinary unsigned uploads. Create the preset
# in Cloudinary console: Settings > Upload > Add upload preset > Signing mode: Unsigned.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=frula_listings_unsigned

# --- Mapbox (maps) ---
MAPBOX_TOKEN=your-mapbox-token

# --- Resend (transactional email) ---
RESEND_API_KEY=your-resend-key
EMAIL_FROM=Frula Homes <noreply@frulahomes.com>
EMAIL_REPLY_TO=hello@frulahomes.com

# --- Site URL (REQUIRED in production) ---
PUBLIC_SITE_URL=http://localhost:3000

# --- Dream Home Alerts (cron secret) ---
# Any random string. Used to authenticate the alert processing endpoint.
ALERTS_SECRET=change-me-to-a-random-string

# --- Sentry (error monitoring — optional) ---
# Create a free project at sentry.io, grab the DSN, paste it here.
# NUXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# --- Stripe (payments — Phase 2) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
